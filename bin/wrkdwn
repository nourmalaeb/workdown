#!/usr/bin/env bash
# wrkdwn — a private documentation layer on top of a public git repo.
#
#   wrkdwn clone <public-url> [dir] [--private <url>]   clone + attach workdown repo
#   wrkdwn init [--local] [<workdown-url>]               attach workdown repo to existing clone
#   wrkdwn skill install                               install the agent skill (~/.claude/skills)
#   wrkdwn rm <file.wrk.md> [...]                      stage deletion of workdown doc(s)
#   wrkdwn <any-git-command>                           git, scoped to the workdown repo
#
# The workdown repo shares this working tree but tracks ONLY *.wrk.md files.
# Plain `git` never sees them; `workdown` never sees anything else.
set -euo pipefail

WORKDOWN_BRANCH="main"

# ---------------------------------------------------------------- helpers

derive_workdown_url() {
  # org/project(.git) -> org/project-workdown(.git)
  local url="$1"
  if [[ "$url" == *.git ]]; then
    printf '%s-workdown.git\n' "${url%.git}"
  else
    printf '%s-workdown\n' "$url"
  fi
}

repo_root() {
  git rev-parse --show-toplevel 2>/dev/null || {
    echo "wrkdwn: not inside a git repository" >&2
    exit 1
  }
}

detect_git_host() {
  local url="$1" host=""
  if [[ "$url" =~ ^https?://([^/]+) ]]; then
    host="${BASH_REMATCH[1]}"
  elif [[ "$url" =~ ^git@([^:]+): ]]; then
    host="${BASH_REMATCH[1]}"
  fi
  case "${host:-}" in
    github.com)    echo "github" ;;
    gitlab.com)    echo "gitlab" ;;
    bitbucket.org) echo "bitbucket" ;;
    *)             echo "${host:-unknown}" ;;
  esac
}

create_hint() {
  local workdown_url="$1"
  local origin_url host
  origin_url="$(git remote get-url origin 2>/dev/null || true)"
  host="$(detect_git_host "$origin_url")"
  case "$host" in
    github)
      local repo="${workdown_url#*github.com[/:]}"
      echo "  gh repo create ${repo%.git} --private"
      ;;
    gitlab)
      local repo="${workdown_url#*gitlab.com[/:]}"
      echo "  glab repo create ${repo%.git} --private"
      ;;
    *)
      echo "  create a PRIVATE repo at $workdown_url using your git host's UI or CLI"
      ;;
  esac
}

warn_foreign_paths() {
  # The whitelist exclude only constrains honest local staging; nothing stops
  # the remote from tracking arbitrary paths, which pull/checkout would then
  # write into the shared working tree. Detect and warn loudly.
  local gd="$1" foreign
  foreign="$(git --git-dir="$gd" ls-tree -r --name-only "$WORKDOWN_BRANCH" 2>/dev/null | grep -v '\.wrk\.md$' || true)"
  [[ -z "$foreign" ]] && return 0
  {
    echo "wrkdwn: WARNING — the workdown repo tracks files that are not *.wrk.md:"
    while IFS= read -r p; do echo "wrkdwn:     $p"; done <<<"$foreign"
    echo "wrkdwn: it must only ever track workdown docs. These paths can be written"
    echo "wrkdwn: over real files in your code checkout by pull/checkout/merge."
    echo "wrkdwn: Inspect them and remove them from the workdown repo."
  } >&2
}

# ---------------------------------------------------------------- init

cmd_init() {
  local root workdown_url="" local_only=false
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --local) local_only=true; shift ;;
      *) workdown_url="$1"; shift ;;
    esac
  done

  if [[ "$local_only" == true && -n "$workdown_url" ]]; then
    echo "wrkdwn: --local and a URL are mutually exclusive" >&2
    exit 1
  fi

  root="$(repo_root)"
  cd "$root"
  local gd="$root/.workdown.git"

  # 1. Create or reuse the workdown bare repo
  if [[ "$local_only" == true ]]; then
    if [[ ! -d "$gd" ]]; then
      echo "==> initializing local workdown repo (no remote)"
      git init --bare -q --initial-branch="$WORKDOWN_BRANCH" "$gd"
    else
      echo "==> workdown repo already present"
    fi
  else
    if [[ -z "$workdown_url" && ! -d "$gd" ]]; then
      workdown_url="$(derive_workdown_url "$(git remote get-url origin)")"
      echo "==> no workdown URL given, assuming: $workdown_url"
    fi

    if [[ ! -d "$gd" ]]; then
      if ! git ls-remote "$workdown_url" >/dev/null 2>&1; then
        echo "wrkdwn: can't reach $workdown_url" >&2
        echo "wrkdwn: it may not exist yet — create it (PRIVATE!) and re-run:" >&2
        create_hint "$workdown_url" | while IFS= read -r line; do echo "wrkdwn:   $line" >&2; done
        echo "wrkdwn: or pass a different URL: wrkdwn init <url>" >&2
        echo "wrkdwn: or start local-only (no remote, no team sync): wrkdwn init --local" >&2
        exit 1
      fi
      echo "==> cloning workdown repo"
      git clone --bare "$workdown_url" "$gd"
      git --git-dir="$gd" config remote.origin.fetch '+refs/heads/*:refs/remotes/origin/*'
    else
      echo "==> workdown repo already present"
    fi
  fi

  # 2. Public repo never sees workdown files (info/exclude = uncommitted, reveals nothing)
  local pattern
  for pattern in '*.wrk.md' '.workdown.git/' '.ignore'; do
    grep -qxF "$pattern" .git/info/exclude 2>/dev/null || echo "$pattern" >>.git/info/exclude
  done
  echo "==> public repo excludes written"

  # 2b. Make .wrk.md files visible to fd/ripgrep-backed editor pickers (.ignore
  #     is honoured by fd/rg but invisible to git, so it never leaks the extension)
  grep -qxF '!*.wrk.md' .ignore 2>/dev/null || echo '!*.wrk.md' >>.ignore
  echo "==> .ignore written (fd/rg will show .wrk.md files in editor pickers)"

  # 3. Workdown repo sees ONLY workdown files (recursive whitelist)
  local ex="$gd/info/exclude"
  if ! grep -qxF '!*.wrk.md' "$ex" 2>/dev/null; then
    mkdir -p "$(dirname "$ex")"
    printf '*\n!*/\n!*.wrk.md\n' >>"$ex"
  fi
  echo "==> workdown repo whitelist written"

  # 4. Pre-push hook: leaks die locally before CI ever sees them
  local hook=.git/hooks/pre-push
  if [[ ! -f "$hook" ]] || ! grep -q 'wrk\.md' "$hook"; then
    cat >>"$hook" <<'HOOK'
#!/usr/bin/env bash
# Block any push whose commits introduce *.wrk.md files.
while read -r _local_ref local_sha _remote_ref remote_sha; do
  [[ "$local_sha" =~ ^0+$ ]] && continue  # deleting a ref
  if [[ "$remote_sha" =~ ^0+$ ]]; then range="$local_sha"; else range="$remote_sha..$local_sha"; fi
  if git rev-list "$range" 2>/dev/null | head -500 | while read -r c; do
       git diff-tree --no-commit-id --name-only -r "$c"
     done | grep -E '\.wrk\.md$' >/dev/null; then
    echo "pre-push: BLOCKED — a commit in this push touches a .wrk.md file." >&2
    exit 1
  fi
done
exit 0
HOOK
    chmod +x "$hook"
  fi
  echo "==> pre-push leak guard installed"

  # 5. Materialize existing workdown docs into the working tree
  if git --git-dir="$gd" rev-parse --verify "$WORKDOWN_BRANCH" >/dev/null 2>&1; then
    warn_foreign_paths "$gd"
    git --git-dir="$gd" --work-tree="$root" checkout "$WORKDOWN_BRANCH" -- '*.wrk.md' 2>/dev/null || true
    git --git-dir="$gd" symbolic-ref HEAD "refs/heads/$WORKDOWN_BRANCH"
    echo "==> workdown docs checked out"
  else
    echo "==> workdown repo is empty; write your first doc, then: wrkdwn add <file> && wrkdwn commit"
  fi

  echo "==> done"
}

# ---------------------------------------------------------------- clone

cmd_clone() {
  local public_url="" dir="" workdown_url="" args=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
    --private)
      workdown_url="$2"
      shift 2
      ;;
    *)
      args+=("$1")
      shift
      ;;
    esac
  done
  public_url="${args[0]:?usage: wrkdwn clone <public-url> [dir] [--private <url>]}"
  dir="${args[1]:-$(basename "${public_url%.git}")}"
  [[ -n "$workdown_url" ]] || workdown_url="$(derive_workdown_url "$public_url")"

  echo "==> cloning public repo"
  git clone "$public_url" "$dir"
  cd "$dir"
  cmd_init "$workdown_url"
  echo
  echo "Ready: cd $dir"
}

# ---------------------------------------------------------------- rm

cmd_rm() {
  local root
  root="$(repo_root)"
  local gd="$root/.workdown.git"
  if [[ ! -d "$gd" ]]; then
    echo "wrkdwn: no workdown repo at $gd (run 'wrkdwn setup' or 'wrkdwn clone')" >&2
    exit 1
  fi
  warn_foreign_paths "$gd"
  local arg
  for arg in "$@"; do
    [[ "$arg" == -* || "$arg" == *.wrk.md ]] || {
      echo "wrkdwn rm: '$arg' is not a .wrk.md file" >&2
      exit 1
    }
  done
  exec git --git-dir="$gd" --work-tree="$root" rm "$@"
}

# ---------------------------------------------------------------- skill

cmd_skill() {
  case "${1:-}" in
  install)
    local dest="$HOME/.claude/skills/workdown"
    mkdir -p "$dest"
    write_skill_md >"$dest/SKILL.md"
    echo "==> installed agent skill at $dest/SKILL.md"
    ;;
  *)
    echo "usage: wrkdwn skill install" >&2
    exit 1
    ;;
  esac
}

write_skill_md() {
  cat <<'SKILL'
---
name: workdown
description: Read and maintain private team documentation (*.wrk.md files) that lives alongside code but is tracked in a separate private "workdown" git repo via the `wrkdwn` CLI. Use this skill whenever you are working in a repository that contains a .workdown.git directory or any *.wrk.md files, whenever the user mentions wrkdwn, workdown, workdown docs, or workdown repo, and whenever you are about to plan, modify, or explain code in such a repository — read the relevant workdown docs BEFORE making changes, and record decisions, caveats, and TODOs in them AFTER making changes.
---

# Workdown docs

This repository has a private documentation layer: files ending in `.wrk.md`
sit next to the code they describe but are tracked in a separate private repo
(`.workdown.git`), managed with the `wrkdwn` CLI. The public repo's git never sees
them. They are authoritative team context: plans, decisions, tradeoffs,
gotchas, and TODOs.

## Before changing code

1. Look for `.wrk.md` files in the directory you're working in and its
   ancestors (e.g. `find . -name '*.wrk.md'` from the repo root, or check the
   nearest ones). Read them — they often explain why the code is the way it is.
2. Check `PLANS/` at the repo root (if present) for cross-cutting docs.

## Where to put docs

Docs live **next to the code they describe**. An agent or teammate editing
`src/auth/middleware.ts` should find context in `src/auth/Doc.wrk.md` or
`src/auth/middleware.wrk.md` — not in a top-level wiki they have to remember
to consult.

Naming:
- `Doc.wrk.md` — the directory-level doc. Describes what the directory as a
  whole does, cross-cutting decisions, and gotchas for anyone working in it.
- `<feature>.wrk.md` — a file-level doc for a specific complex file (e.g.
  `wrkdwn.wrk.md` next to the `wrkdwn` binary). Use when a single file
  carries enough history or decisions to warrant its own doc.

When creating a new doc: start with frontmatter only (`docs:`, `status:`,
`todos:` if any). Add body entries as decisions are made. A stub is better
than no doc — it signals that the directory is documented even before anything
interesting has happened.

## Frontmatter (optional)

`.wrk.md` files may open with YAML frontmatter. All fields are optional — omit
any that aren't relevant. Scan frontmatter before reading the body to decide
how carefully to engage with the full doc.

```yaml
---
docs: "One-liner describing what this feature or directory does"
status: active          # planned | active | stable | deprecated | archived
contributors:
  - github-username
todos:
  - one-liner per outstanding action item
gotchas:
  - one-liner per trap or non-obvious constraint
human_notes:
  - one-liner per thing a human should know before the session starts
related:
  - ../path/to/other/Doc.wrk.md
archived_from: path/to/original/Doc.wrk.md   # only present when status: archived
archived_reason: "why the feature/directory was removed"    # only present when status: archived
---
```

When writing entries: add to `todos:` for new action items, `gotchas:` for
traps you hit, `human_notes:` for things a human should know. Remove resolved
`todos:` entries — the body entry is the permanent record. Keep each line
short; full context belongs in the body.

## After changing code

Record anything a teammate or future agent would need: non-obvious decisions,
rejected alternatives, gotchas you hit, unfinished work. Append to the nearest
relevant `.wrk.md`, or create one next to the code. Keep entries short,
dated, and signed — identify people by their GitHub username, and agents by
agent name:

```markdown
## 2026-06-11 — session token redesign (nourmalaeb + claude)
Decision: rotate refresh tokens on every use. Tradeoff: ...
Gotcha: KV eventual consistency means ...
TODO: backfill expiry on legacy rows before removing fallback.
```

### When to include a PR reference

Include a `PR:` line when the change is significant enough that a reviewer
would want to trace the full discussion: a new feature, a removal, or an
architectural decision. Skip it for routine fixes or small tweaks.

To get the current PR number run `gh pr view --json number,url` (returns
nothing if no open PR exists yet — omit the reference in that case).

```markdown
## 2026-06-11 — session token redesign (nourmalaeb + claude)
PR: https://github.com/org/repo/pull/42
Decision: rotate refresh tokens on every use. Tradeoff: ...
Gotcha: KV eventual consistency means ...
TODO: backfill expiry on legacy rows before removing fallback.
```

## Committing workdown docs

Use `workdown`, which is git scoped to the private repo:

```bash
wrkdwn status
wrkdwn add path/to/file.wrk.md
wrkdwn commit -m "describe the docs change"
wrkdwn push
```

NEVER commit `.wrk.md` files with plain `git`, and never use `git add -f` on
them. If `wrkdwn` is missing or `.workdown.git` doesn't exist, run `wrkdwn init`
(or tell the user) rather than improvising.

## Archiving deleted docs

When code is removed, its `.wrk.md` docs should be archived to
`.WORKDOWN-ARCHIVE/` rather than deleted — history and decisions remain useful
after the code is gone. `.WORKDOWN-ARCHIVE/` is invisible to the public repo
(it only contains `.wrk.md` files).

**Reading `wrkdwn status` output for deletions:**

- Staged `D` (first column: `D `) — deletion was done via `wrkdwn rm`;
  intentional, just needs a commit.
- Unstaged `D` (second column: ` D`) — deletion happened outside wrkdwn;
  surface these to the human and ask what to do before committing anything.

**Before removing a directory**, run `wrkdwn status` to find any `.wrk.md`
files inside it. Show them to the human and ask: archive or permanently delete?

**Archive flow:**
  1. Restore: `wrkdwn checkout main -- <original-path>`
  2. Add to frontmatter:
     ```yaml
     status: archived
     archived_from: <original-path-relative-to-repo-root>
     archived_reason: "one-liner: why the feature/directory was removed"
     ```
  3. Move: `mkdir -p .WORKDOWN-ARCHIVE/<original-dir> && mv <original-path> .WORKDOWN-ARCHIVE/<original-path>`
  4. Stage: `wrkdwn rm <original-path> && wrkdwn add .WORKDOWN-ARCHIVE/<original-path>`
  5. Commit: `wrkdwn commit -m "archive docs for removed <feature>"`

Use `wrkdwn rm <file.wrk.md>` to permanently delete a doc with no archiving.

## Confidentiality rules (critical)

- NEVER quote, paste, or summarize the contents of any `.wrk.md` file in
  commit messages, PR titles or descriptions, issue comments, code comments,
  or any other artifact that lands in the public repo.
- Referring to a doc by filename is acceptable; reproducing its contents is not.
- Never run `wrkdwn clean` (the wrapper blocks it; do not work around the block —
  from the workdown repo's view the entire codebase is "ignored files").
SKILL
}

# ---------------------------------------------------------------- dispatch

case "${1:-}" in
clone)
  shift
  cmd_clone "$@"
  ;;
init)
  shift
  cmd_init "$@"
  ;;
setup)
  shift
  cmd_init "$@"
  ;;
skill)
  shift
  cmd_skill "$@"
  ;;
rm)
  shift
  cmd_rm "$@"
  ;;
clean)
  echo "wrkdwn: 'clean' is disabled — it would treat the whole codebase as ignored files." >&2
  echo "wrkdwn: remove stray .wrk.md files by hand instead." >&2
  exit 1
  ;;
"" | -h | --help)
  sed -n '2,10p' "$0" | sed 's/^# \{0,1\}//'
  ;;
*)
  root="$(repo_root)"
  gd="$root/.workdown.git"
  if [[ ! -d "$gd" ]]; then
    echo "wrkdwn: no workdown repo at $gd (run 'wrkdwn setup' or 'wrkdwn clone')" >&2
    exit 1
  fi
  warn_foreign_paths "$gd"
  case "$1" in
  pull | checkout | switch | restore | merge | reset | rebase | stash | cherry-pick)
    # These can write tracked files into the code working tree — no exec, so
    # the foreign-path check can run again on whatever the command brought in.
    rc=0
    git --git-dir="$gd" --work-tree="$root" "$@" || rc=$?
    warn_foreign_paths "$gd"
    exit "$rc"
    ;;
  *)
    exec git --git-dir="$gd" --work-tree="$root" "$@"
    ;;
  esac
  ;;
esac
